{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FayedDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "FrontendUrl": "https://fayedplatform.com",
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "Fayed_API",
    "Audience": "Fayed_Frontend",
    "DurationInDays": 7
  },
  "EmailSettings": {
    "Server": "sandbox.smtp.mailtrap.io",
    "Port": "2525",
    "SenderEmail": "info@fayedplatform.com",
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD"
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUDINARY_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "Ai": {
    "Provider": "ItiGateway",
    "ItiGateway": {
      "BaseUrl": "http://apiaccess.iti.net.eg/student",
      "ApiKey": "YOUR_ITI_GATEWAY_API_KEY_HERE",
      "Model": "anthropic.claude-sonnet-4-6"
    },
    "Gemini": {
      "ApiKey": "YOUR_GOOGLE_GEMINI_API_KEY_HERE",
      "Model": "gemini-1.5-flash"
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6"
    }
  },
  "Gemini": {
    "ApiKey": "YOUR_GOOGLE_GEMINI_API_KEY_HERE"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
